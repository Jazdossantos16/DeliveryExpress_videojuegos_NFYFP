# Standard Unity gitignore
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory dumps
*.lldb
*.stackdump

# Autogenerated VS/MD/ReSharper solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity3D generated meta files
# (We keep meta files, they are required for asset references)

# Unity3D generated file logs
sysinfo.pem

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/[Ll]ayout.bin
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/[Cc]ontent[Cc]atalog.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
